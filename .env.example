# Environment
NEXT_PUBLIC_STORE_MODE=demo
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact (leave empty until configured — do not invent an email)
CONTACT_EMAIL=

# Stripe (test mode for demo)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_TAX_ENABLED=false

# Email (Resend or compatible)
RESEND_API_KEY=
EMAIL_FROM=

# Optional Supabase for order persistence
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Security
ORDER_TRACKING_SECRET=change-me-to-a-long-random-string
RATE_LIMIT_SALT=change-me-rate-limit-salt
